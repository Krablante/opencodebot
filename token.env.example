OPENCODEBOT_TOKEN=123456:telegram-token-from-botfather
OPENCODEBOT_ALLOWED_USER_IDS=123456789
OPENCODEZ_SERVER_PASSWORD=your-opencodez-password

# Optional. Required only when config.local.json enables the artifact gateway.
# OPENCODEBOT_ARTIFACT_TOKEN=replace-with-a-long-random-token

# Optional. Required only when config.local.json enables speech transcription.
# OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# Optional. Required only for the local Telegram Bot API sidecar.
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=your-telegram-api-hash
